#include <stdio.h>
#include <stdlib.h>
#include <ctype.h>

// Stack Node
struct Node {
    int data;
    struct Node* next;
};

struct Node* top = NULL;

// Push
void push(int x) {
    struct Node* newNode = (struct Node*)malloc(sizeof(struct Node));
    newNode->data = x;
    newNode->next = top;
    top = newNode;
}

// Pop
int pop() {
    if (top == NULL) return -1;
    int val = top->data;
    struct Node* temp = top;
    top = top->next;
    free(temp);
    return val;
}

int main() {
    char exp[100];
    int i = 0;

    fgets(exp, sizeof(exp), stdin);

    while (exp[i] != '\0') {
        if (isdigit(exp[i])) {
            push(exp[i] - '0');
        }
        else if (exp[i] == '+' || exp[i] == '-' || exp[i] == '*' || exp[i] == '/') {
            int b = pop();
            int a = pop();
            int res;

            if (exp[i] == '+') res = a + b;
            else if (exp[i] == '-') res = a - b;
            else if (exp[i] == '*') res = a * b;
            else res = a / b;

            push(res);
        }
        i++;
    }

    printf("%d\n", pop());
    return 0;
}