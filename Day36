#include <stdio.h>

#define MAX 100

int queue[MAX];
int front = 0, rear = 0;

// Enqueue
void enqueue(int x) {
    queue[rear] = x;
    rear = (rear + 1) % MAX;
}

// Dequeue
void dequeue() {
    front = (front + 1) % MAX;
}

// Display
void display(int count) {
    int i = front;
    for (int j = 0; j < count; j++) {
        printf("%d ", queue[i]);
        i = (i + 1) % MAX;
    }
}

int main() {
    int n, m, x;

    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        scanf("%d", &x);
        enqueue(x);
    }

    scanf("%d", &m);

    for (int i = 0; i < m; i++) {
        dequeue();
    }

    display(n);

    return 0;
}