#include <stdio.h>

#define MAX 100

int stack[MAX];
int top = -1;

void push(int x) {
    stack[++top] = x;
}

void pop() {
    if (top != -1)
        top--;
}

int main() {
    int n, m;

    scanf("%d", &n);

    // Push elements
    for (int i = 0; i < n; i++) {
        int x;
        scanf("%d", &x);
        push(x);
    }

    // Number of pops
    scanf("%d", &m);

    for (int i = 0; i < m; i++) {
        pop();
    }

    // Print remaining stack
    for (int i = top; i >= 0; i--) {
        printf("%d ", stack[i]);
    }

    return 0;
}